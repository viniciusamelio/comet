+    /// Creates a `Data` object from an arbitrary externally-driven byte
+    /// stream, e.g. a Cloudflare Worker request body bridged from a JS
+    /// `ReadableStream`.
+    ///
+    /// Unlike [`Data::local()`], this does not buffer the body before
+    /// dispatching into Rocket: bytes are read from `stream` on demand as
+    /// routes/guards consume the request body.
+    ///
+    /// `stream` need not be `Send`: wasm32 under Workers has no threads, so
+    /// it's wrapped in a `SendWrapper` internally to satisfy Rocket's
+    /// otherwise-`Send`-bound internals soundly.
+    #[cfg(feature = "worker")]
+    #[inline]
+    pub fn from_stream<S>(stream: S) -> Data<'r>
+        where S: futures::stream::Stream<Item = io::Result<bytes::Bytes>> + 'r
+    {
+        let stream = send_wrapper::SendWrapper::new(stream);
+        Data::from(crate::data::data_stream::RawStream::Worker(Box::pin(stream)))
+    }
+
